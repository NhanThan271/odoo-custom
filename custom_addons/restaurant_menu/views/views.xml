<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <!-- LIST VIEW -->
  <record id="view_restaurant_menu_list" model="ir.ui.view">
    <field name="name">restaurant.menu.list</field>
    <field name="model">product.template</field>
    <field name="arch" type="xml">
      <list>
        <field name="name" />
        <field name="list_price" />
        <field name="food_category" />
        <field name="active" />
      </list>
    </field>
  </record>

  <!-- FORM VIEW -->
  <record id="view_restaurant_menu_form" model="ir.ui.view">
    <field name="name">restaurant.menu.form</field>
    <field name="model">product.template</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="name" />
            <field name="list_price" />
            <field name="food_category" />
            <field name="description_food" />
            <field name="active" />
            <field name="spicy_level" />
            <field name="cooking_time" />
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ACTION -->
  <record id="action_restaurant_menu" model="ir.actions.act_window">
    <field name="name">Restaurant Menu</field>
    <field name="res_model">product.template</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- MENU -->
  <menuitem id="restaurant_food_menu"
    name="Foods"
    parent="restaurant_table.restaurant_root_menu"
    action="action_restaurant_menu"
    sequence="2" />

</odoo>