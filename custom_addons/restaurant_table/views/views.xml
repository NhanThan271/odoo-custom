<odoo>

  <!-- VIEW -->
  <record id="restaurant_custom_table_form" model="ir.ui.view">
    <field name="name">restaurant.custom.table.form</field>
    <field name="model">restaurant.custom.table</field>
    <field name="arch" type="xml">
      <form string="Restaurant Table">
        <sheet>
          <group>
            <field name="name" />
            <field name="seats" />
            <field name="floor_id" />
            <field name="note" />
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- ACTION -->
  <record id="action_restaurant_table" model="ir.actions.act_window">
    <field name="name">Tables</field>
    <field name="res_model">restaurant.custom.table</field>
    <field name="view_mode">list,form</field>
  </record>

  <!-- MENU -->
  <menuitem id="restaurant_root_menu" name="Restaurant" />

  <menuitem id="menu_restaurant_table"
    name="Tables"
    parent="restaurant_root_menu"
    action="action_restaurant_table" />

</odoo>